# Copy to .env and fill in. NEVER commit the real .env.

# --- Threads (Meta) Graph API ---
THREADS_ACCESS_TOKEN=your-long-lived-threads-access-token
THREADS_USER_ID=17841441777154923

# --- Google Sheets ---
# The full contents of the service-account JSON key, as a single-line string.
# Tip: cat service_account.json | python -c "import json,sys;print(json.dumps(json.load(sys.stdin)))"
GOOGLE_SA_JSON={"type":"service_account","project_id":"...","private_key":"..."}
SPREADSHEET_ID=your-google-spreadsheet-id

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Email (SMTP + STARTTLS) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your-smtp-app-password
MAIL_TO=you@example.com

# --- Report ---
REPORT_LOOKBACK_DAYS=7
